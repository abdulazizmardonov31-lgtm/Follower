#include <Servo.h>

Servo myServo;

int ldrLeft = A0;
int ldrRight = A1;

int pos = 90;

void setup() {
  myServo.attach(9);
  Serial.begin(9600);
}

void loop() {
  int leftValue = analogRead(ldrLeft);
  int rightValue = analogRead(ldrRight);

  Serial.print("Left: ");
  Serial.print(leftValue);
  Serial.print(" | Right: ");
  Serial.println(rightValue);

  if (leftValue > rightValue + 50) {
    pos--;
  } 
  else if (rightValue > leftValue + 50) {
    pos++;
  }

  pos = constrain(pos, 0, 180);
  myServo.write(pos);

  delay(100);
}
